# Copy this file to .env for local testing (never commit the real .env).
# In GitHub Actions, these are set as repo secrets instead — see .github/workflows/daily.yml

# Google AI Studio free-tier API keys: https://aistudio.google.com/app/apikey
# Provide SEVERAL keys comma-separated (each from a DIFFERENT Google account or
# Cloud project — the free-tier quota is per project). The bot rotates between
# them on every request and skips to the next key when one is rate-limited.
#   Example: GEMINI_API_KEYS=AIzaKey1,AIzaKey2,AIzaKey3
GEMINI_API_KEYS=

# (Legacy) single key — used only if GEMINI_API_KEYS is empty
GEMINI_API_KEY=

# From @BotFather after creating your bot
TELEGRAM_TOKEN=

# Your personal chat id (the bot DMs you directly — it is never added to groups/channels).
# Get it by sending /start to your bot, then visiting:
#   https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# and copying the numeric "id" from "chat" (e.g. 123456789).
TELEGRAM_CHAT_ID=
